# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values before running locally.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL  (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (Settings → API → service_role secret)
# ⚠ This key bypasses Row Level Security — keep it private.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Secret used to sign JWTs and Flask session cookies.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string

# Admin dashboard password
ADMIN_PASSWORD=change-me-admin-password

# Google Sheets ID for optional result export (leave blank to disable)
GOOGLE_SHEET_ID=

# Flask runtime flags (set to "true" only in development)
FLASK_DEBUG=false
